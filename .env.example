# Database — create a Neon project at https://neon.tech, copy the connection string
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Auth.js — generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# App URL — used for emails, TON Connect manifest, cron self-calls
APP_URL=http://localhost:3000

# Cron Bearer secret — generate with: openssl rand -hex 32
CRON_SECRET=

# Resend — email alerts. Without RESEND_API_KEY, sendAlertEmail logs and skips.
RESEND_API_KEY=
RESEND_FROM=alerts@pingup.dev

# Telegram bot — alerts + verification webhook.
# After deploy, register the webhook with secret_token=$TELEGRAM_WEBHOOK_SECRET
# so the handler can verify the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# TON — for paid subscriptions. Without TON_PAYMENT_ADDRESS, /subscribe/[id] throws.
# TONCENTER_API_KEY is optional; without it you're rate-limited to ~1 req/s.
TON_PAYMENT_ADDRESS=
TONCENTER_API_KEY=

# Optional: house-ad sponsor card shown to Free users. Without these, the
# slot falls back to an upgrade-to-Pro card. Plain text — no HTML injected.
ADS_TITLE=
ADS_BODY=
ADS_URL=
ADS_CTA=
